---
layout: base.njk
title: "From the Booth"
permalink: /blog/
---
<section class="blog-hero">
  <div class="wrap-wide">
    <div class="sec-head"><span class="eyebrow">From the Booth</span><span class="rule"></span></div>
    <h1 class="blog-h1">From the<br>Booth.</h1>
    <nav class="cat-nav" aria-label="Categories">
      <a class="active" href="/blog/">All</a>
      {% for c in collections.categories %}<a href="/blog/category/{{ c.slug }}/">{{ c.title }}</a>{% endfor %}
    </nav>
  </div>
</section>
<section class="blog-list-section">
  <div class="wrap-wide">
    <div class="blog-grid">
      {% for post in collections.posts %}
      <a class="post" href="{{ post.url }}">
        <div class="post-img"><div style="background-image:url({{ post.data.featured or post.data.cover }})"></div></div>
        <div class="post-meta"><span>{{ post.date | monthDay }}</span><span>·</span><span>{{ post.data.categories[0] }}</span></div>
        <h3>{{ post.data.title }}</h3>
        <p>{{ post.data.excerpt }}</p>
        <span class="post-more">Read More →</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
