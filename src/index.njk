/* ——— Giant "CONTACT" fixed-footer panel ———
   Matches spencergabor.work: this block is position:fixed at the
   bottom of the viewport, behind the rest of the page. As the user
   scrolls to the end of the page, preceding sections scroll UP and
   reveal it in place — a reveal-by-occlusion effect, not a transform
   parallax. Preceding sections need solid backgrounds so they occlude
   it while the user is reading them (the contact/white section above
   provides this at the end of the flow).

   The spacer below reserves scroll height equal to the panel so the
   page can be scrolled far enough to fully reveal it. */
.big-contact {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  /* Full-viewport height so the word can grow enormous and the meta
     column sits at the bottom. flex-end + column aligns meta to the
     bottom edge, matching Spencer's layout. */
  height: 100vh;
  min-height: 100vh;
  width: 100%;
  background: var(--color-grey-ghost);
  color: var(--color-ink);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  gap: 32px;
  /* Bottom padding reserves room for the fixed meta strip (~212px tall)
     so the word doesn't get clipped by it. Keep generous headroom. */
  padding: 64px 0 240px;
  /* Sits behind everything else in the document flow. Regular sections
     above have their own backgrounds and sit at the default z-index,
     so they occlude this until scrolled past. */
  z-index: -1;
  pointer-events: auto;
  overflow: hidden;
}
.big-contact-word {
  display: block;
  /* Inter Medium — matches spencergabor.work's closing footer wordmark.
     Scoped to this element only; rest of the site stays on Helvetica. */
  font-family: "Inter", "Helvetica", "Arial", sans-serif;
  font-weight: 900;
  /* One solid line spanning the viewport width. Tuned so the 7-letter
     word CONTACT in Helvetica bold fills the viewport edge-to-edge
     without horizontal overflow at full scale. */
  font-size: 20.5vw;
  line-height: 0.82;
  letter-spacing: -0.04em;
  text-transform: uppercase;
  color: var(--color-white);
  text-align: center;
  margin: auto 0 0;
  user-select: none;
  white-space: nowrap;
  /* Scroll-driven scale: JS sets --reveal from 0..MAX as the user
     scrolls the spacer past the viewport. At 0 the word is flat
     (fully squished); at MAX it's stretched vertically to fill the
     panel height, matching Spencer's oversized look. Transform
     origin is the bottom so the word grows UP toward the top of
     the panel from the meta column below. */
  transform: scaleY(var(--reveal, 1));
  transform-origin: center bottom;
  will-change: transform;
}
/* Meta column sits at the bottom of the fixed CONTACT panel (hence on
   the same grey background as the word). It's at document root in the
   DOM — NOT a child of .big-contact — because .big-contact lives at
   z-index:-1 and children can't escape that negative stacking context.
   Positioned-fixed to the bottom of the viewport so it always appears
   directly beneath CONTACT whenever the panel is revealed. Because the
   flow sections above have opaque backgrounds, they occlude this strip
   while the user is reading them; it only becomes visible once the
   user scrolls into the spacer and the panel is exposed. */
.big-contact-meta {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  padding: 28px 24px 44px;
  font-family: var(--font-family-headline);
  font-size: 13px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-ink);
  /* Bold throughout — all meta text reads heavy to match the CONTACT
     wordmark's weight and hold its own against the giant grey band. */
  font-weight: 700;
  /* Same grey as the CONTACT panel so meta and word share one band. */
  background: var(--color-grey-ghost);
  /* z-index: 5 puts the meta column above flow sections so clicks land.
     When flow sections fully occlude the CONTACT panel (user is reading
     higher sections), we want meta hidden too. JS toggles --meta-op
     based on scroll position — 0 until the reveal begins, 1 once it's
     started, giving meta the "pop in with the grey panel" behavior
     that matches the user's mental model without fading. */
  z-index: 5;
  opacity: var(--meta-op, 0);
  pointer-events: var(--meta-pe, none);
}
.big-contact-meta a {
  color: var(--color-ink);
  text-decoration: none;
  /* Hover: blue tint + slight lift. Motion reinforces clickability. */
  transition: color 220ms var(--ease-out-quart),
              transform 220ms var(--ease-out-quart);
  display: inline-block;
}
.big-contact-meta a:hover {
  /* White + extra-heavy on hover — strong contrast against the grey
     band so the active link really pops. Still nudges up 2px. */
  color: var(--color-white);
  font-weight: 900;
  transform: translateY(-2px);
}
.big-contact-email {
  font-size: 16px;
  letter-spacing: 0.16em;
  margin-bottom: 2px;
}
.big-contact-copy {
  margin-top: 14px;
  font-size: 10px;
  letter-spacing: 0.18em;
  color: rgba(54, 54, 54, 0.55);
}
/* Spacer sits in the document flow and reserves room equal to TWICE
   the fixed panel's viewport height so there's a long scroll window
   for the reveal animation (word squishes to nothing at the start,
   grows to full height at the end). */
.big-contact-spacer {
  height: 200vh;
  min-height: 200vh;
  pointer-events: none;
}
/* Occlusion chain for the fixed CONTACT panel:
   Every section in the flow must have its own opaque background so the
   panel only shows once the user scrolls past .contact and into the
   spacer. Body background must be TRANSPARENT so the fixed panel can
   show through at the end — the sections above occlude it piece-by-piece.
   nav/hero/portfolio/about/blog get explicit white backgrounds below.
   .reps/.coaching/.contact already set their own. */
body { background: transparent; }
.nav,
.hero,
#portfolio,
#about,
#blog { background: var(--color-white); }
/* html must be transparent so the fixed panel (z-index:-1) is visible
   at the end of scroll; the opaque sections above occlude it earlier. */
html { background: transparent; }

