<script>
/* =================================================================
   PORTFOLIO is loaded from portfolio.json (edit that file to change
   the lineup). This inline array is the offline fallback used when
   the JSON can't be fetched (e.g. opening index.html directly
   from disk without a server).
   ================================================================= */
let PORTFOLIO = [
  { youtube: 'MGMZHuDN-y4', title: ['NHL','on TNT'], eyebrow: 'Promo · TNT', meta: 'Stanley Cup', color: 'ink', span: 7, shape: 'wide' },
  { youtube: 'L5QokvTq2HQ', title: ['Vivi','Headphones'], eyebrow: 'Commercial · Launch', meta: 'Vivi Product Launch', color: 'cream', span: 5, shape: 'wide' },
  { youtube: 'xMF5cy9mif0', title: ['Epic','Groceries'], eyebrow: 'Commercial · Hyundai', meta: 'w/ John Krasinski', color: 'blue', span: 4, shape: 'tall' },
  { youtube: '8H1SwTjS0J8', title: ['Pluribus'], eyebrow: 'Promo · Apple TV+', meta: 'Limited Series', color: 'purple', span: 4, shape: 'tall' },
  { youtube: 'ItDEzR1s_Cs', title: ['Spaceballs 2','The New One'], eyebrow: 'Trailer · Netflix', meta: 'Trailer', color: 'green', span: 4, shape: 'tall' },
  { youtube: 'pL--wWygzBE', title: ['Georgia','vs Alabama'], eyebrow: 'Promo · ESPN / ABC', meta: 'College Football', color: 'cream', span: 6, shape: 'wide' },
  { youtube: 'I24REvS3wtY', title: ['The First','Omen'], eyebrow: 'Trailer · 20th Century', meta: 'Retro Trailer', color: 'ink', span: 6, shape: 'wide' },
  { youtube: '0R5itL20wK4', title: ['Australian','Open'], eyebrow: 'Promo · ESPN', meta: 'ESPN Australian Open', color: 'green', span: 4 },
  { youtube: 'boSpnSzFTrE', title: ['Pluto TV','Halloween'], eyebrow: 'Promo · Pluto TV', meta: 'Halloween Hits', color: 'purple', span: 4 },
  { youtube: 'NxzfxyjGjwE', title: ['Ford v','Ferrari'], eyebrow: 'Trailer · 20th Century Fox', meta: 'Ford v Ferrari', color: 'blue', span: 4 },
];

/* =================================================================
   BLOG_POSTS — the "From the Booth" snapshot.
   This static site has no WordPress backend, so these three posts
   are rendered directly. When you add a blog backend later, point
   loadBlog() at its JSON/REST feed and these become the fallback.
   ================================================================= */
const BLOG_POSTS = {% endraw %}{{ collections.posts | boothCardsJson | safe }}{% raw %};

const esc = s => (s || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
const nl2br = s => esc(s).replace(/\n/g, '<br>');

/* Render portfolio tiles */
function renderTiles() {
  const root = document.getElementById('tile-grid');
  root.innerHTML = PORTFOLIO.map(t => {
    const cls = ['tile', t.color, 'col-' + t.span, t.shape || ''].filter(Boolean).join(' ');
    const bg = t.image ? `<div class="tile-bg" style="background-image:url(${esc(t.image)});opacity:0.6"></div><div class="tile-scrim"></div>` : '';
    // Video thumbnail. Use mqdefault.jpg (320x180, true 16:9 with
    // no letterbox bars) as the default — it exists for every
    // YouTube video and fills the tile cleanly. We then upgrade
    // to maxresdefault.jpg below if the HD version exists, for a
    // sharper image on large tiles. Avoid hqdefault.jpg/sddefault.jpg —
    // those are 4:3 with black bars baked in around the video frame.
    const hoverImg = t.youtube ? `<div class="tile-hover-img" data-yt="${esc(t.youtube)}" style="background-image:url(https://img.youtube.com/vi/${esc(t.youtube)}/mqdefault.jpg)"></div>` : '';
    // Corner play badge on video tiles — signals "this is a video"
    // at a glance, in addition to the faint resting thumbnail.
    const playBadge = t.youtube ? `<span class="tile-play-badge" aria-hidden="true">&#9654;</span>` : '';
    const isExternal = !t.youtube;
    const href = isExternal ? esc(t.href || '#') : '#';
    const tgt = isExternal ? ' target="_blank" rel="noopener"' : '';
    const titleArr = Array.isArray(t.title) ? t.title : String(t.title).split('\n');
    const titleHtml = titleArr.map(esc).join('<br>');
    const titlePlain = titleArr.join(' ');
    const data = t.youtube ? ` data-video="${esc(t.youtube)}" data-title="${esc(titlePlain)}"` : '';
    // Bottom-right indicator: ↗ for external links so you know
    // the tile opens in a new tab. Video tiles already carry the
    // corner play badge, so no bottom indicator is needed there.
    const arrow = isExternal ? '↗' : '';
    return `<a href="${href}"${tgt} class="${cls}"${data}>
${hoverImg}
${bg}
${playBadge}
<span class="tile-eyebrow">${esc(t.eyebrow)}</span>
<div>
<div class="tile-title">${titleHtml}</div>
<div class="tile-meta"><span>${esc(t.meta)}</span>${arrow ? `<span class="tile-play">${arrow}</span>` : ''}</div>
</div>
</a>`;
  }).join('');
  /* Re-wire video clicks */
  root.querySelectorAll('.tile[data-video]').forEach(tile => {
    tile.addEventListener('click', e => {
      e.preventDefault();
      const id = tile.dataset.video, title = tile.dataset.title || '';
      document.getElementById('vmodal-title').textContent = title;
      document.getElementById('vmodal-iframe').src = 'https://www.youtube.com/embed/' + id + '?autoplay=1&rel=0';
      document.getElementById('vmodal').style.display = 'flex';
      document.body.style.overflow = 'hidden';
    });
  });

  /* Upgrade mqdefault → maxresdefault for videos that have HD thumbs available.
     YouTube returns a placeholder 120x90 gray "no thumbnail" image (not a 404) when
     maxresdefault doesn't exist, so we detect it by measuring naturalWidth. */
  root.querySelectorAll('.tile-hover-img[data-yt]').forEach(el => {
    const id = el.dataset.yt;
    const probe = new Image();
    probe.onload = () => {
      if (probe.naturalWidth > 320) {
        el.style.backgroundImage = `url(https://img.youtube.com/vi/${id}/maxresdefault.jpg)`;
      }
    };
    probe.src = `https://img.youtube.com/vi/${id}/maxresdefault.jpg`;
  });
}

/* Render blog cards. img may be null → render typographic color placeholder. */
function renderBlog(posts, note) {
  const placeholderColors = ['cream', 'blue', 'green', 'purple'];
  const root = document.getElementById('blog-grid');
  root.innerHTML = posts.slice(0, 3).map((p, i) => {
    const imgBlock = p.img
      ? `<div class="post-img"><div style="background-image:url(${esc(p.img)})"></div></div>`
      : `<div class="post-img post-img-placeholder" data-color="${placeholderColors[i % placeholderColors.length]}"><span>${esc((p.cat || 'JD').slice(0, 2).toUpperCase())}</span></div>`;
    return `<a href="${esc(p.url)}" target="_blank" rel="noopener" class="post">
${imgBlock}
<div class="post-meta"><span>${esc(p.date)}</span><span>·</span><span>${esc(p.cat)}</span></div>
<h3>${nl2br(p.title)}</h3>
<p>${esc(p.excerpt)}</p>
<span class="post-more">Read More →</span>
</a>`;
  }).join('');
  document.getElementById('blog-status').textContent = note || '';
}

renderTiles();
renderBlog(BLOG_POSTS, '');

/* Render obfuscated email addresses client-side.
   Domain is split so no plain-text email exists in the HTML. */
const _buildEmail = el => {
  const u = el.dataset.u, d = el.dataset.d, t = el.dataset.t;
  if (!u || !d || !t) return '';
  return u + String.fromCharCode(64) + d + '.' + t;
};
document.querySelectorAll('.js-email').forEach(a => {
  const addr = _buildEmail(a);
  if (!addr) return;
  const span = a.querySelector('span') || a;
  span.textContent = addr;
  if (a.tagName === 'A') a.setAttribute('href', 'mailto:' + addr);
});
/* Plain-text email spans (non-link) — e.g. in the Reps section */
document.querySelectorAll('.js-email-text').forEach(el => {
  const addr = _buildEmail(el);
  if (addr) el.textContent = addr;
});

/* Try to load portfolio.json — if found, re-render with fresh data.
   Silent fallback to inline PORTFOLIO when fetch fails (e.g. file://). */
(async () => {
  try {
    const res = await fetch('portfolio.json', { cache: 'no-store' });
    if (!res.ok) return;
    const data = await res.json();
    if (Array.isArray(data?.tiles) && data.tiles.length) {
      PORTFOLIO = data.tiles;
      renderTiles();
    }
  } catch (e) { /* keep fallback */ }
})();

/* Modal close */
function closeVideo() {
  document.getElementById('vmodal-iframe').src = '';
  document.getElementById('vmodal').style.display = 'none';
  document.body.style.overflow = '';
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeVideo(); });

/* ——— Reveal on scroll ———
   Adds .is-in to each target when it scrolls into view; the CSS transitions on
   .rep and .bio-lede (incl. the "contemporary" accent) do the rest.
   Hardened so the text can NEVER stay permanently hidden: if motion is reduced,
   if IntersectionObserver is unsupported, or if a callback is ever missed
   (background/throttled tab, refresh mid-page), a scroll/resize/load sweep
   reveals anything that's in view. */
(() => {
  const targets = [...document.querySelectorAll('.rep, .bio-lede')];
  if (!targets.length) return;
  const reveal = el => el.classList.add('is-in');
  const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce || !('IntersectionObserver' in window)) { targets.forEach(reveal); return; }

  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) { reveal(entry.target); io.unobserve(entry.target); }
    });
  }, { threshold: 0.2, rootMargin: '0px 0px -10% 0px' });
  targets.forEach(t => io.observe(t));

  const sweep = () => {
    let remaining = false;
    targets.forEach(t => {
      if (t.classList.contains('is-in')) return;
      const r = t.getBoundingClientRect();
      if (r.top < window.innerHeight * 0.85 && r.bottom > 0) { reveal(t); io.unobserve(t); }
      else remaining = true;
    });
    if (!remaining) {
      window.removeEventListener('scroll', sweep);
      window.removeEventListener('resize', sweep);
    }
  };
  window.addEventListener('scroll', sweep, { passive: true });
  window.addEventListener('resize', sweep);
  window.addEventListener('load', () => setTimeout(sweep, 200));
})();

/* ——— Giant CONTACT: scroll-driven scaleY on the wordmark ———
   Mirror spencergabor.work: the word starts squished (short) and
   stretches to full height as the last section scrolls away and
   the fixed panel is revealed. We drive this from the position of
   the .big-contact-spacer: when its TOP is at the viewport bottom
   (panel just peeking), --reveal = 0; when its BOTTOM is at the
   viewport bottom (panel fully revealed), --reveal = 1.
   rAF-throttled; honors prefers-reduced-motion. */
(() => {
  const word = document.getElementById('big-contact-word');
  const spacer = document.querySelector('.big-contact-spacer');
  const meta = document.querySelector('.big-contact-meta');
  if (!word || !spacer) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    word.style.setProperty('--reveal', '1');
    return;
  }
  const MIN = 0.0; // scaleY at the start of the reveal (fully squished to nothing)
  const MAX = 4.2; // scaleY at the end — stretched vertically to fill the panel height.
  // (The word's natural line-box height is ~17% of viewport; x4.2 ~= 72%.)
  let ticking = false;

  const update = () => {
    ticking = false;
    const rect = spacer.getBoundingClientRect();
    const vh = window.innerHeight || document.documentElement.clientHeight;
    // Progress: 0 when spacer top is at viewport bottom (just starting),
    // 1 when spacer bottom is at viewport bottom (fully revealed).
    const total = rect.height; // spacer height (~100vh)
    const progressed = vh - rect.top; // how far past the top we've scrolled
    let p = progressed / total;
    if (p < 0) p = 0;
    if (p > 1) p = 1;
    const reveal = MIN + (MAX - MIN) * p;
    word.style.setProperty('--reveal', reveal.toFixed(3));
    // Meta pops in IMMEDIATELY once the reveal starts (no gradual fade)
    // so the contact links are visible the moment the grey panel is
    // exposed — matches the user's expectation that info shows up with
    // the CONTACT word, not delayed.
    if (meta) {
      const show = p > 0.01;
      meta.style.setProperty('--meta-op', show ? '1' : '0');
      meta.style.setProperty('--meta-pe', show ? 'auto' : 'none');
    }
  };

  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(update);
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll);
  update();
})();

/* Mobile nav toggle.
   Open/close the hamburger, keep aria-expanded in sync, auto-close
   when a link is picked (so #anchor scrolls without the menu blocking). */
(function(){
  const nav = document.querySelector('.nav');
  const toggle = nav && nav.querySelector('.nav-toggle');
  const links = nav && nav.querySelector('.nav-links');
  if (!nav || !toggle || !links) return;

  const setOpen = open => {
    nav.classList.toggle('is-open', open);
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  };

  toggle.addEventListener('click', () => {
    setOpen(!nav.classList.contains('is-open'));
  });

  links.addEventListener('click', e => {
    if (e.target.closest('a')) setOpen(false);
  });

  /* Close on Escape or when viewport grows past the mobile breakpoint. */
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && nav.classList.contains('is-open')) setOpen(false);
  });
  window.addEventListener('resize', () => {
    if (window.innerWidth > 780 && nav.classList.contains('is-open')) setOpen(false);
  });
})();
