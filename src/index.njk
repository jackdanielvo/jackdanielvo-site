<!-- Font override safety net: guarantees Helvetica regardless of cached tokens.css -->
<style>
:root {
  color-scheme: light;
  --font-family-headline: "Helvetica", "Arial", "Helvetica Neue", sans-serif !important;
}
</style>
<style>
/* =================================================================
   Jack Daniel · Landing page
   Built on the Spencer Gabor design system (tokens.css).
   Every value here resolves to a token; no bespoke colors/sizes.
   ================================================================= */
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
body {
  font: var(--font-body);
  color: var(--color-ink);
  background: var(--color-white);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
img { max-width: 100%; display: block; }

/* ——— Layout primitives (from --max-width, --padding, --gap) ——— */
.wrap {
  max-width: var(--max-width); /* 860px */
  padding: 0 var(--padding);
  margin: 0 auto;
}
.wrap-wide { max-width: 1200px; padding: 0 var(--padding); margin: 0 auto; }

/* ——— Reusable primitives that live on .sg-root ——— */
h1, h2, h3, h4, p, a, button, li { margin: 0; padding: 0; }
h1, h2, .display {
  font-family: var(--font-family-headline);
  font-weight: 400;
  line-height: 0.82;
  letter-spacing: -0.02em;
  text-transform: uppercase;
}
.eyebrow {
  font-family: var(--font-family-headline);
  font-size: 9px;
  line-height: 1;
  letter-spacing: 0.9px;
  text-transform: uppercase;
  color: var(--color-ink);
}
.para-cap {
  font-family: var(--font-family-headline);
  font-size: 14px;
  line-height: 1.2;
  letter-spacing: 1.26px;
  text-transform: uppercase;
  color: var(--color-ink);
}
.body {
  font: var(--font-body);
  color: var(--color-ink);
  text-transform: none;
  letter-spacing: 0;
}

/* ——— Pill chips & buttons (--radius-pill: 800px) ——— */
.chip, .btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--color-grey-ghost);
  color: var(--color-black);
  padding: 14px 22px;
  border: 0;
  border-radius: var(--radius-pill);
  font-family: var(--font-family-headline);
  font-size: 22.4px;
  line-height: 1;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  transition: background 320ms var(--ease-out-quart),
              color 320ms var(--ease-out-quart),
              transform 320ms var(--ease-out-back);
}
.chip-sm {
  font-size: 14px;
  letter-spacing: 1.26px;
  padding: 9px 16px;
}
.chip:hover, .btn:hover {
  background: var(--color-amber, #B88A3E);
  color: var(--color-white);
  transform: translateY(-1px);
}
.btn-solid {
  background: var(--color-ink);
  color: var(--color-white);
}
.btn-solid:hover {
  /* Amber with a literal fallback so the button still renders if the
     --color-amber token isn't loaded (e.g. stale tokens.css cache). */
  background: var(--color-amber, #B88A3E);
  color: var(--color-white);
}
.btn-solid svg { transition: transform 320ms var(--ease-out-back); }
.btn-solid:hover svg { transform: scale(1.15); }

/* ——— Hero CTA pair — plum + amber cross-swap ———
   View Reel sits in the deep brand plum; Book Jack in the warm
   amber. Hovering either one swaps to the other color so the two
   buttons visually play off each other. Scoped to .hero-actions
   so the portfolio/coaching/nav buttons keep their original
   neutral-on-ink palette. */
.hero-actions .btn-solid {
  background: var(--tile-purple, #3C0350);
  color: var(--color-white);
}
.hero-actions .btn-solid:hover,
.hero-actions .btn-solid:focus {
  background: var(--color-amber, #B88A3E);
  color: var(--color-white);
}
.hero-actions .btn:not(.btn-solid) {
  background: var(--color-amber, #B88A3E);
  color: var(--color-white);
}
.hero-actions .btn:not(.btn-solid):hover,
.hero-actions .btn:not(.btn-solid):focus {
  background: var(--tile-purple, #3C0350);
  color: var(--color-white);
}

/* Larger button variant — used for the portfolio CTA below the tile grid. */
.btn-lg {
  padding: 20px 32px;
  font-size: 26px;
  letter-spacing: 0.02em;
}
.btn-lg .btn-arrow {
  display: inline-block;
  margin-left: 4px;
  transition: transform 320ms var(--ease-out-back);
}
.btn-lg:hover .btn-arrow { transform: translateX(6px); }
@media (max-width: 780px) {
  .btn-lg { padding: 16px 26px; font-size: 20px; }
}

/* Wrapper that centers the CTA under the tile grid and gives it room. */
.tile-grid-cta {
  display: flex;
  justify-content: center;
  margin-top: 56px;
}
@media (max-width: 780px) {
  .tile-grid-cta { margin-top: 36px; }
}

/* ——— Header ——— */
.nav {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px var(--padding);
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-bottom: var(--border-hairline);
}
.mark {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-family-headline);
  color: var(--color-ink);
  text-decoration: none;
  line-height: 1;
}
.mark-logo {
  display: block;
  width: 36px;
  height: 36px;
  border-radius: 4px;
  flex: 0 0 auto;
}
.mark-text {
  font-size: 18px;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  white-space: nowrap;
}
.mark-text .mark-text-sub {
  font-weight: 500;
  opacity: 0.55;
  margin-left: 6px;
  letter-spacing: 0.08em;
}
@media (max-width: 480px) {
  .mark-text .mark-text-sub { display: none; }
  .mark-logo { width: 32px; height: 32px; }
  .mark-text { font-size: 16px; }
}
.nav-links {
  display: flex;
  gap: 8px;
  list-style: none;
}
.nav-links a {
  display: inline-flex;
  align-items: center;
  padding: 9px 16px;
  background: transparent;
  color: var(--color-ink);
  border-radius: var(--radius-pill);
  font-family: var(--font-family-headline);
  font-size: 14px;
  line-height: 1;
  letter-spacing: 1.26px;
  text-transform: uppercase;
  text-decoration: none;
  transition: background 280ms var(--ease-out-quart), color 280ms var(--ease-out-quart);
}
.nav-links a:hover {
  background: var(--color-grey-ghost);
}
.nav-links a.active {
  background: var(--color-ink);
  color: var(--color-white);
}
.nav-links a.active:hover {
  background: var(--color-amber, #B88A3E);
  color: var(--color-white);
}
/* Client Area pill — matches the brand violet used inside the client portal */
.nav-links a.client-area {
  background: #3C0350;
  color: var(--color-white) !important;
  font-weight: 600;
}
.nav-links a.client-area:hover {
  background: #5b1a73;
  color: var(--color-white);
}

/* ——— Hero — oversized ghost-stack headline ——— */
.hero {
  position: relative;
  padding: 80px var(--padding) 64px;
  overflow: hidden;
  border-bottom: var(--border-hairline);
}
.hero-inner {
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
}
.hero-stack {
  position: relative;
  line-height: 0.9;
}
.hero-stack .h-ghost,
.hero-stack .h-ink {
  font-family: var(--font-family-headline);
  font-size: clamp(96px, 22vw, 320px);
  line-height: 0.9;
  letter-spacing: -0.03em;
  text-transform: uppercase;
  display: block;
}
.hero-stack .h-ghost { color: var(--color-grey-ghost); }
.hero-stack .h-ink { color: var(--color-ink); margin-top: 0; }
.hero-meta {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-top: 32px;
}
.live-dot {
  width: 8px;
  height: 8px;
  background: var(--tile-green);
  border-radius: var(--radius-circle);
  box-shadow: 0 0 0 4px rgba(55,175,93,0.25);
  animation: pulse 1.6s var(--ease-in-out-sine) infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.55; transform: scale(0.85); }
}
.hero-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 36px;
}
.hero-tagline {
  font-family: var(--font-family-headline);
  font-size: clamp(22px, 2.6vw, 42px);
  line-height: 1;
  letter-spacing: -0.01em;
  text-transform: uppercase;
  color: var(--color-ink);
  margin-top: 48px;
  max-width: 820px;
}
.hero-tagline .gh { color: var(--color-grey-ghost); }

/* ——— Section header (eyebrow + thin rule + big heading) ——— */
section { padding: 96px 0; }
.sec-head {
  display: flex;
  align-items: baseline;
  gap: 20px;
  margin-bottom: 48px;
}
.sec-head .eyebrow { flex: 0 0 auto; }
.sec-head .rule {
  flex: 1 1 auto;
  height: 1px;
  background: rgba(0,0,0,0.15);
}
.sec-head .more {
  font-family: var(--font-family-headline);
  font-size: 14px;
  letter-spacing: 1.26px;
  text-transform: uppercase;
  color: var(--color-ink);
  text-decoration: none;
}
.sec-head .more:hover { color: var(--tile-blue); }

/* ——— Bio ——— */
.bio-lede {
  font-family: var(--font-family-headline);
  font-size: clamp(44px, 6.2vw, 96px);
  line-height: 0.9;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  color: var(--color-ink);
  margin-bottom: 40px;
}
.bio-lede .gh { color: var(--color-grey-ghost); }
/* Accent word — colored + slides/fades in on scroll. Starts offset so
   the reveal reads as a deliberate entrance; transitions only kick in
   once .is-in is toggled by the IntersectionObserver below. */
.bio-lede .bio-accent {
  display: inline-block;
  color: var(--color-amber, #B88A3E);
  font-style: italic;
  opacity: 0;
  transform: translateX(60vw);
  transition:
    opacity 1200ms var(--ease-out-quart) 650ms,
    transform 1600ms var(--ease-out-quart) 650ms;
}
.bio-lede.is-in .bio-accent {
  opacity: 1;
  transform: translateX(0);
}
/* Respect reduced-motion: no slide/fade, just show the word in place. */
@media (prefers-reduced-motion: reduce) {
  .bio-lede .bio-accent { transition: none; transform: none; }
}
.bio-body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  max-width: 860px;
  margin: 0 auto;
}
.bio-body p {
  font: var(--font-body);
  font-size: 15px;
  line-height: 1.5;
  color: var(--color-ink);
  letter-spacing: 0;
  text-transform: none;
}
.bio-body p.secondary { color: #666; }
.bio-sig {
  margin-top: 32px;
  font-family: var(--font-family-headline);
  font-size: 14px;
  letter-spacing: 1.26px;
  text-transform: uppercase;
  color: var(--color-ink);
  display: flex;
  align-items: center;
  gap: 12px;
}
.bio-sig::before {
  content: "";
  width: 40px;
  height: 1px;
  background: var(--color-ink);
}

/* ——— Portfolio tiles — the only colored surface ——— */
.tile-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 12px;
}
.tile {
  position: relative;
  border-radius: var(--radius-card);
  overflow: hidden;
  aspect-ratio: 4 / 3;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 24px;
  text-decoration: none;
  transition: transform 520ms var(--ease-out-quart);
}
.tile:hover { transform: translateY(-2px); }
.tile-bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  transition: transform 720ms var(--ease-out-quart);
  z-index: 0;
}
.tile:hover .tile-bg { transform: scale(1.04); }
/* Video-thumbnail image shown faintly on every video tile so it's
   clear at a glance that the tile represents a video. Brightens
   on hover (or keyboard focus) to preview the full thumbnail. */
.tile-hover-img {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  opacity: 0.28;
  transform: scale(1.02);
  transition: opacity 320ms var(--ease-out-quart), transform 520ms var(--ease-out-quart);
  z-index: 0;
}
/* Cream tiles need a touch more contrast since the backing color
   is light — a darker thumbnail against cream looks washed out at
   the same opacity that reads fine against ink. */
.tile.cream .tile-hover-img { opacity: 0.38; }
.tile-hover-img::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.55) 100%);
}
.tile:hover .tile-hover-img,
.tile:focus-within .tile-hover-img { opacity: 0.78; transform: scale(1.04); }
.tile.cream:hover .tile-hover-img,
.tile.cream:focus-within .tile-hover-img { opacity: 0.88; }
.tile-overlay {
  position: absolute;
  inset: 0;
  mix-blend-mode: multiply;
  z-index: 1;
}
.tile-scrim {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.45) 100%);
  z-index: 2;
}
.tile > *:not(.tile-hover-img):not(.tile-bg):not(.tile-scrim):not(.tile-overlay):not(.tile-play-badge) { position: relative; z-index: 3; }

.tile-eyebrow {
  display: inline-flex;
  align-self: flex-start;
  font-family: var(--font-family-headline);
  font-size: 11px;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: var(--color-white);
  padding: 6px 12px;
  border-radius: var(--radius-pill);
  background: rgba(0,0,0,0.35);
}
.tile-title {
  font-family: var(--font-family-headline);
  font-size: clamp(28px, 3vw, 44px);
  line-height: 0.85;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  color: var(--color-white);
}
.tile-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12px;
  font-family: var(--font-family-headline);
  font-size: 11px;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.85);
}
.tile-play {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-circle);
  background: var(--color-white);
  color: var(--color-ink);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 280ms var(--ease-out-back);
}
.tile:hover .tile-play { transform: scale(1.08); }

/* Variant colors per tile */
.tile.cream { background: var(--tile-cream); }
.tile.cream .tile-eyebrow,
.tile.cream .tile-title,
.tile.cream .tile-meta { color: var(--color-ink); }
.tile.cream .tile-eyebrow { background: rgba(54,54,54,0.14); }
.tile.cream .tile-scrim { background: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(54,54,54,0.1) 100%); }
/* On hover, the (dark) YouTube thumbnail is revealed behind the cream tile,
   so swap the ink text back to white for legibility — matches the other tiles. */
.tile.cream:hover .tile-eyebrow,
.tile.cream:hover .tile-title { color: var(--color-white); }
.tile.cream:hover .tile-meta { color: rgba(255,255,255,0.85); }
.tile.cream:hover .tile-eyebrow { background: rgba(0,0,0,0.35); }

.tile.blue { background: var(--tile-blue); }
.tile.green { background: var(--tile-green); }
.tile.purple { background: var(--tile-purple); }
.tile.ink { background: var(--color-ink); }

/* ——— Corner play badge ———
   A small circular ▶ badge sits in the top-right of every video
   tile to unmistakably signal "this is a playable video" — a
   secondary, always-on cue that complements the faint thumbnail
   showing underneath the tile color. Grows slightly on hover. */
.tile-play-badge {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 32px;
  height: 32px;
  border-radius: var(--radius-circle, 50%);
  background: rgba(255, 255, 255, 0.92);
  color: var(--color-ink, #1a1a1a);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  line-height: 1;
  padding-left: 2px; /* optical-center the ▶ glyph */
  z-index: 3;
  transition: transform 280ms var(--ease-out-back, cubic-bezier(0.34, 1.56, 0.64, 1)),
              background 200ms ease;
  pointer-events: none;
}
.tile:hover .tile-play-badge,
.tile:focus-within .tile-play-badge {
  transform: scale(1.12);
  background: var(--color-white, #ffffff);
}

/* Span classes for asymmetric grid */
.col-4 { grid-column: span 4; }
.col-5 { grid-column: span 5; }
.col-6 { grid-column: span 6; }
.col-7 { grid-column: span 7; }
.col-8 { grid-column: span 8; }
.col-12 { grid-column: span 12; }

.tile.tall { aspect-ratio: 4 / 5; }
.tile.wide { aspect-ratio: 16 / 9; }

/* When a row mixes a wide-7 with a wide-5, the 16:9 aspect ratios produce
   different heights. Drop the aspect on the 5-col wide so CSS Grid can
   stretch it to match its row-neighbor. */
.tile.wide.col-5 { aspect-ratio: auto; }

/* ——— Reps ——— */
.reps {
  background: #FAFAFA;
  border-top: var(--border-hairline);
  border-bottom: var(--border-hairline);
}
.rep-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  max-width: 1000px;
  margin: 0 auto;
}
.rep {
  position: relative;
  padding: 28px;
  background: var(--color-white);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-soft);
  overflow: hidden;
  /* Enter animation: fade + rise */
  opacity: 0;
  transform: translateY(28px);
  transition:
    opacity 720ms var(--ease-out-quart),
    transform 720ms var(--ease-out-quart),
    box-shadow 320ms var(--ease-out-quart);
}
.rep.is-in {
  opacity: 1;
  transform: translateY(0);
}
.rep:nth-child(2) { transition-delay: 120ms; }
/* Hover lift + deeper shadow */
.rep:hover {
  transform: translateY(-6px);
  box-shadow: 0 24px 60px rgba(54,54,54,0.12), 0 2px 4px rgba(54,54,54,0.04);
}
/* Diagonal arrow in top-right — fades in on hover */
.rep::after {
  content: "↗";
  position: absolute;
  top: 22px;
  right: 24px;
  font-family: var(--font-family-headline);
  font-size: 22px;
  color: var(--color-ink);
  opacity: 0;
  transform: translate(-6px, 6px);
  transition: opacity 320ms var(--ease-out-quart), transform 320ms var(--ease-out-quart);
}
.rep:hover::after {
  opacity: 0.6;
  transform: translate(0, 0);
}
/* Stagger the inner content on enter */
.rep > * {
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 520ms var(--ease-out-quart), transform 520ms var(--ease-out-quart);
}
.rep.is-in > * { opacity: 1; transform: translateY(0); }
.rep.is-in > *:nth-child(1) { transition-delay: 120ms; }
.rep.is-in > *:nth-child(2) { transition-delay: 220ms; }
.rep.is-in > *:nth-child(3) { transition-delay: 300ms; }
.rep.is-in > *:nth-child(4) { transition-delay: 360ms; }
.rep.is-in > *:nth-child(5) { transition-delay: 420ms; }
.rep:nth-child(2).is-in > *:nth-child(1) { transition-delay: 240ms; }
.rep:nth-child(2).is-in > *:nth-child(2) { transition-delay: 340ms; }
.rep:nth-child(2).is-in > *:nth-child(3) { transition-delay: 420ms; }
.rep:nth-child(2).is-in > *:nth-child(4) { transition-delay: 480ms; }
.rep:nth-child(2).is-in > *:nth-child(5) { transition-delay: 540ms; }

.rep .eyebrow { margin-bottom: 16px; display: block; }
/* Hairline sweep under the agency name — draws across on hover */
.rep h3 {
  position: relative;
  font-family: var(--font-family-headline);
  font-size: clamp(36px, 4vw, 56px);
  line-height: 0.85;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  color: var(--color-ink);
  padding-bottom: 16px;
  margin-bottom: 16px;
}
.rep h3::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 1px;
  background: var(--color-ink);
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform 520ms var(--ease-out-quart);
}
.rep:hover h3::after { transform: scaleX(1); }
.rep .people { margin-bottom: 12px; font-weight: 500; }
.rep .tel {
  font-family: var(--font-family-headline);
  font-size: 18px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-ink);
  margin-bottom: 4px;
  transition: letter-spacing 420ms var(--ease-out-quart);
}
