---
layout: base.njk
title: "Client Area"
permalink: /client-area/
---
<section class="portal">
  <div class="portal-wrap">
    <div class="sec-head"><span class="eyebrow">Client Area</span><span class="rule"></span></div>

    <div id="portal-status" class="portal-msg">Loading…</div>

    <!-- Login -->
    <div id="portal-login" hidden>
      <h1 class="portal-h1">Your files,<br>on demand.</h1>
      <p class="portal-lede">Enter the email your delivery was sent to and we'll send you a one-click sign-in link — no password needed.</p>
      <form id="portal-login-form" class="portal-form">
        <input type="email" id="portal-email" name="email" placeholder="you@agency.com" autocomplete="email" required>
        <button type="submit" class="btn-portal">Email me a link →</button>
      </form>
      <p id="portal-login-note" class="portal-note" hidden></p>
    </div>

    <!-- Files -->
    <div id="portal-files" hidden></div>
  </div>
</section>

<style>
.portal { padding: 56px 0 96px; }
.portal-wrap { max-width: 820px; margin: 0 auto; padding: 0 var(--padding); }
.portal-h1 { font-family: var(--font-family-headline); font-size: clamp(40px,6vw,84px); line-height:0.88; letter-spacing:-0.03em; text-transform:uppercase; margin:8px 0 18px; }
.portal-lede { font: var(--font-body); font-size:17px; line-height:1.6; color:#555; max-width:520px; margin:0 0 24px; }
.portal-msg { font-family: var(--font-family-headline); font-size:12px; letter-spacing:0.12em; text-transform:uppercase; color:#999; padding:24px 0; }
.portal-form { display:flex; gap:10px; flex-wrap:wrap; max-width:520px; }
.portal-form input { flex:1 1 240px; border:0; border-bottom:1.5px solid var(--color-ink); background:transparent; padding:12px 2px; font-family:var(--font-family-body); font-size:16px; color:var(--color-ink); outline:none; }
.portal-form input:focus { border-bottom-color: var(--tile-purple); }
.btn-portal { display:inline-flex; align-items:center; background:var(--tile-purple); color:#fff; border:0; border-radius:var(--radius-pill); padding:13px 26px; font-family:var(--font-family-headline); font-size:14px; letter-spacing:0.08em; text-transform:uppercase; cursor:pointer; transition:background 240ms var(--ease-out-quart); }
.btn-portal:hover { background: var(--color-amber,#B88A3E); }
.portal-note { margin-top:18px; font-size:15px; color:var(--tile-green); }
.portal-note.err { color:#b00; }

.portal-greet { font-family:var(--font-family-headline); font-size:13px; letter-spacing:0.12em; text-transform:uppercase; color:#888; margin-bottom:24px; display:flex; justify-content:space-between; align-items:center; gap:12px; }
.portal-greet a { color:var(--tile-purple); text-decoration:none; }
.delivery { border:1px solid var(--color-grey-ghost); border-radius:var(--radius-card); padding:24px 26px; margin-bottom:22px; }
.delivery-title { font-family:var(--font-family-headline); font-size:clamp(26px,3.4vw,40px); line-height:0.9; letter-spacing:-0.02em; text-transform:uppercase; margin:0 0 6px; }
.delivery-meta { font-family:var(--font-family-headline); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:#999; margin-bottom:18px; }
.delivery-note { background:var(--tile-cream); border-radius:10px; padding:14px 18px; margin:0 0 18px; font-size:14px; line-height:1.55; font-style:italic; color:#5a4a25; }
.delivery-note b { display:block; font-style:normal; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-amber,#B88A3E); margin-bottom:5px; }
.file-row { display:flex; align-items:center; justify-content:space-between; gap:14px; padding:12px 0; border-top:1px solid var(--color-grey-ghost); }
.file-row:first-of-type { border-top:0; }
.file-name { font-weight:500; font-size:15px; }
.file-specs { font-family:var(--font-family-headline); font-size:11px; letter-spacing:0.08em; text-transform:uppercase; color:#999; margin-top:3px; }
.file-dl { flex:0 0 auto; display:inline-flex; align-items:center; background:var(--color-ink); color:#fff; border-radius:var(--radius-pill); padding:9px 18px; font-family:var(--font-family-headline); font-size:12px; letter-spacing:0.08em; text-transform:uppercase; text-decoration:none; transition:background 240ms var(--ease-out-quart); }
.file-dl:hover { background:var(--tile-purple); }
.dl-all { margin-top:16px; }
.expired { color:#b00; }
</style>

<script>
(function () {
  var statusEl = document.getElementById("portal-status");
  var loginEl  = document.getElementById("portal-login");
  var filesEl  = document.getElementById("portal-files");
  var esc = function (s) { return String(s == null ? "" : s).replace(/[&<>"']/g, function (c) { return ({ "&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;" })[c]; }); };
  var fmtSize = function (b) { b = Number(b)||0; if (b>=1073741824) return (b/1073741824).toFixed(1)+" GB"; if (b>=1048576) return (b/1048576).toFixed(1)+" MB"; if (b>=1024) return (b/1024).toFixed(1)+" KB"; return b+" B"; };
  var fmtDate = function (iso) { if(!iso) return ""; try { return new Date(iso).toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"}); } catch(e){ return ""; } };
  var fmtDur = function (s) { if(!s) return ""; s=Math.round(s); return Math.floor(s/60)+":"+String(s%60).padStart(2,"0"); };
  var params = new URLSearchParams(location.search);

  function show(el){ el.hidden=false; } function hide(el){ el.hidden=true; }

  function showLogin(prefillErr){
    hide(statusEl); hide(filesEl); show(loginEl);
    var note = document.getElementById("portal-login-note");
    if (prefillErr){ note.textContent = prefillErr; note.classList.add("err"); show(note); }
    document.getElementById("portal-login-form").addEventListener("submit", function (e) {
      e.preventDefault();
      var email = document.getElementById("portal-email").value.trim();
      var btn = e.target.querySelector("button"); btn.disabled = true; btn.textContent = "Sending…";
      fetch("/api/portal/request-link", { method:"POST", headers:{"content-type":"application/json"}, body: JSON.stringify({ email: email }) })
        .then(function(r){ return r.json(); })
        .then(function(d){ note.classList.remove("err"); note.textContent = d.message || "Check your inbox."; show(note); btn.textContent="Sent ✓"; })
        .catch(function(){ note.classList.add("err"); note.textContent="Something went wrong. Please try again."; show(note); btn.disabled=false; btn.textContent="Email me a link →"; });
    });
  }

  function specLine(f){
    var bits=[]; if(f.label) bits.push(labelHuman(f.label));
    if(f.duration_sec) bits.push(fmtDur(f.duration_sec));
    if(f.sample_rate) bits.push(Math.round(f.sample_rate/1000)+" kHz");
    if(f.bit_depth) bits.push(f.bit_depth+"-bit");
    bits.push(fmtSize(f.size_bytes));
    return bits.join(" · ");
  }
  function labelHuman(k){ return ({final_approved:"Final Approved",cutdown:"Cutdown",pickup:"Pickup / Alts",reference:"Reference",raw:"Raw / Unprocessed"})[k] || k; }

  function renderFiles(data){
    hide(statusEl); hide(loginEl); show(filesEl);
    var focus = params.get("d");
    var html = '<div class="portal-greet"><span>Signed in as ' + esc(data.email) + '</span><a href="/client-area/logout">Sign out</a></div>';
    if (!data.deliveries.length) { html += '<p class="portal-lede">No deliveries yet. When Jack sends you files, they\'ll appear here.</p>'; filesEl.innerHTML = html; return; }
    data.deliveries.forEach(function (d) {
      var expired = d.expires_at && new Date(d.expires_at).getTime() < Date.now();
      html += '<div class="delivery" id="d-' + esc(d.id) + '">';
      html += '<h2 class="delivery-title">' + esc(d.title) + '</h2>';
      var meta = []; if(d.agency_name) meta.push(esc(d.agency_name)); if(d.delivered_at) meta.push("Delivered " + esc(fmtDate(d.delivered_at)));
      if(d.expires_at) meta.push(expired ? '<span class="expired">Expired</span>' : "Available until " + esc(fmtDate(d.expires_at)));
      html += '<div class="delivery-meta">' + meta.join(" &middot; ") + '</div>';
      if (d.note_from_jack) html += '<div class="delivery-note"><b>Note from Jack</b>' + esc(d.note_from_jack) + '</div>';
      (d.files||[]).forEach(function (f) {
        html += '<div class="file-row"><div><div class="file-name">' + esc(f.display_name) + '</div><div class="file-specs">' + esc(specLine(f)) + '</div></div>'
             + '<a class="file-dl" href="/client-area/dl?delivery=' + encodeURIComponent(d.id) + '&file=' + encodeURIComponent(f.id) + '">Download</a></div>';
      });
      if ((d.files||[]).length > 1) {
        html += '<a class="btn-portal dl-all" data-all="' + esc(d.id) + '" href="#">Download all (' + d.files.length + ') →</a>';
      }
      html += '</div>';
    });
    filesEl.innerHTML = html;
    // "Download all" = trigger each file's signed download with a small stagger.
    filesEl.querySelectorAll("[data-all]").forEach(function (btn) {
      btn.addEventListener("click", function (e) {
        e.preventDefault();
        var d = data.deliveries.find(function(x){ return x.id === btn.getAttribute("data-all"); });
        if(!d) return;
        d.files.forEach(function (f, i) {
          setTimeout(function () {
            var a = document.createElement("a");
            a.href = "/client-area/dl?delivery=" + encodeURIComponent(d.id) + "&file=" + encodeURIComponent(f.id);
            document.body.appendChild(a); a.click(); a.remove();
          }, i * 800);
        });
      });
    });
    if (focus) { var el = document.getElementById("d-" + focus); if (el) el.scrollIntoView({ behavior:"smooth", block:"start" }); }
  }

  // Boot
  var err = params.get("error");
  fetch("/api/portal/me", { headers:{ "accept":"application/json" } })
    .then(function (r) { if (r.status === 200) return r.json().then(renderFiles); showLogin(err); })
    .catch(function () { showLogin(err); });
})();
</script>
