---
layout: base.njk
pagination:
  data: collections.categories
  size: 1
  alias: category
permalink: "/blog/category/{{ category.slug }}/"
eleventyComputed:
  title: "{{ category.title }} — From the Booth"
---
<section class="blog-hero">
  <div class="wrap-wide">
    <div class="sec-head"><span class="eyebrow">From the Booth</span><span class="rule"></span></div>
    <h1 class="blog-h1">{{ category.title }}.</h1>
    <nav class="cat-nav" aria-label="Categories">
      <a href="/blog/">All</a>
      {% for c in collections.categories %}<a {% if c.slug == category.slug %}class="active"{% endif %} href="/blog/category/{{ c.slug }}/">{{ c.title }}</a>{% endfor %}
    </nav>
  </div>
</section>
<section class="blog-list-section">
  <div class="wrap-wide">
    <div class="blog-grid">
      {% for post in category.posts %}
      <a class="post" href="{{ post.url }}">
        {% if post.data.cover %}
        <div class="post-img"><div style="background-image:url({{ post.data.cover }})"></div></div>
        {% else %}
        <div class="post-img post-img-placeholder" data-color="{{ ['cream','blue','green','purple'][loop.index0 % 4] }}"><span>{{ (post.data.categories[0] or 'JD') | truncate(2, true, '') | upper }}</span></div>
        {% endif %}
        <div class="post-meta"><span>{{ post.date | monthDay }}</span><span>·</span><span>{{ post.data.categories[0] }}</span></div>
        <h3>{{ post.data.title }}</h3>
        <p>{{ post.data.excerpt }}</p>
        <span class="post-more">Read More →</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
