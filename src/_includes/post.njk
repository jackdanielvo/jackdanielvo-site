---
layout: base.njk
---
<article class="post-full">
  <div class="post-shell">
    <div class="post-full-meta">
      <span>{{ date | dayMonthCaps }}</span><span class="dot">·</span>
      {% for c in categories %}<a class="post-cat" href="/blog/category/{{ c | slug }}/">{{ c }}</a>{% endfor %}
    </div>
    <h1 class="post-full-title">{{ title }}</h1>
    {% if featured %}<div class="post-full-cover"><img src="{{ featured }}" alt="{{ title }}"></div>{% endif %}
    <div class="post-body">
      {{ content | safe }}
      {% if youtube %}<div class="post-video"><iframe src="https://www.youtube.com/embed/{{ youtube | ytid }}" title="{{ title }}" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe></div>{% endif %}
      {% if video %}<div class="post-video"><video controls preload="metadata" src="{{ video }}"></video></div>{% endif %}
      {% if gallery and gallery.length %}<div class="post-gallery">{% for img in gallery %}<img loading="lazy" src="{{ img }}" alt="{{ title }}">{% endfor %}</div>{% endif %}
    </div>
    <div class="post-foot">
      <a class="post-back" href="/blog/">← All posts</a>
      <a class="post-next" href="/#contact">Book Jack →</a>
    </div>
  </div>
</article>
