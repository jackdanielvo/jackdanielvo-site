---
layout: base.njk
---
<article class="post-full">
  <div class="post-shell">
    <div class="post-full-meta">
      <span>{{ date | dayMonthCaps }}</span><span class="dot">·</span>
      {% for c in categories %}<a class="post-cat" href="/blog/category/{{ c | slug }}/">{{ c }}</a>{% endfor %}
    </div>
    <h1 class="post-full-title">{{ title }}</h1>
    {% if featured %}<div class="post-full-cover"><img src="{{ featured }}" alt="{{ title }}"></div>{% endif %}
    <div class="post-body">
      {{ content | safe }}
    </div>
    <div class="post-foot">
      <a class="post-back" href="/blog/">← All posts</a>
      <a class="post-next" href="/#contact">Book Jack →</a>
    </div>
  </div>
</article>
