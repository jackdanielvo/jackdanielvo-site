---
layout: base.njk
---
<article class="post-full">
  <div class="wrap">
    <a class="post-back" href="/blog/">← From the Booth</a>
    <div class="post-full-meta">
      <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
      {% for c in categories %}<a class="post-cat" href="/blog/category/{{ c | slug }}/">{{ c }}</a>{% endfor %}
    </div>
    <h1 class="post-full-title">{{ title }}</h1>
  </div>
  {% if cover %}
  <div class="wrap"><div class="post-full-cover"><img src="{{ cover }}" alt="{{ title }}"></div></div>
  {% endif %}
  <div class="wrap post-body">
    {{ content | safe }}
  </div>
  <div class="wrap post-foot"><a class="post-back" href="/blog/">← All posts</a></div>
</article>
